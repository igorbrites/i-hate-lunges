---
import BaseLayout from "../../layouts/BaseLayout.astro";

const disguised = [
  { emoji: "🇧🇬", name: "Bulgarian Split Squat", verdict: "Split Squat", desc: "A lunge with your back foot on a bench. They added furniture to distract you. It's still a lunge.", image: "/images/exercises/bulgarian-split-squat.jpeg" },
  { emoji: "🔀", name: "Split Squat", verdict: "Stationary Lunge", desc: "A lunge that doesn't move. They literally just renamed it. Zero effort to hide it.", image: "/images/exercises/split-squat.jpg" },
  { emoji: "🏃", name: "Step-Ups", verdict: "Vertical Lunge", desc: "A lunge aimed at the sky. You're still dropping into single-leg knee agony — just upward.", image: "/images/exercises/step-ups.jpg" },
  { emoji: "🔄", name: "Reverse Lunge", verdict: "Backwards Lunge", desc: "It's a lunge. But backwards. Revolutionary? No. Still a lunge? Absolutely.", image: "/images/exercises/reverse-lunge.jpeg" },
  { emoji: "🚶", name: "Walking Lunge", verdict: "Migratory Lunge", desc: "A lunge that travels. Now your suffering covers more ground. How delightful.", image: "/images/exercises/walking-lunge.jpeg" },
  { emoji: "🤸", name: "Jump Lunge", verdict: "Airborne Lunge", desc: "A lunge with flight time. Because regular knee destruction wasn't extreme enough.", image: "/images/exercises/jump-lunge.jpeg" },
  { emoji: "🎀", name: "Curtsy Lunge", verdict: "Fancy Lunge", desc: "A lunge dressed up for the ball. Crossing your leg behind you doesn't make it elegant. It makes it worse.", image: "/images/exercises/curtsy-lunge.jpg" },
  { emoji: "📐", name: "Lateral Lunge", verdict: "Sideways Lunge", desc: "A lunge that goes sideways. New direction, same betrayal.", image: "/images/exercises/lateral-lunge.jpeg" },
  { emoji: "⬇️", name: "Deficit Lunge", verdict: "Deeper Lunge", desc: "A lunge from a raised surface. More range of motion means more range of suffering.", image: "/images/exercises/deficit-lunge.jpeg" },
  { emoji: "🕐", name: "Clock Lunge", verdict: "Omnidirectional Lunge", desc: "Lunges in every direction. 360 degrees of regret.", image: "/images/exercises/clock-lunge.jpeg" },
  { emoji: "🔫", name: "Pistol Squat", verdict: "Lunge's Cousin", desc: "Single-leg. Deep knee bend. Requires balance you don't have. If it walks like a lunge and hurts like a lunge…", image: "/images/exercises/pistol-squat.jpg" },
  { emoji: "📦", name: "Box Step-Over", verdict: "Double Lunge", desc: "Step up, step down. That's two lunges. You've been double-charged.", image: "/images/exercises/box-step-over.jpeg" },
  { emoji: "🧗", name: "Stair Climbing", verdict: "Repeated Lunge", desc: "Every step is a single-leg squat. Every flight is a lunge gauntlet. The stairs were a trap all along.", image: "/images/exercises/stair-climbing.jpeg" },
];
---

<BaseLayout title="Lunges in Disguise — I Hate Lunges">
  <section class="disguise animate-in">
    <h1>🕵️ Lunges in Disguise</h1>
    <p class="intro">
      The fitness industry thinks it can fool us by slapping a fancy name on a lunge.
      <strong>We see through the lies.</strong> Here is every exercise that is secretly
      just a lunge wearing a fake mustache.
    </p>

    <ul class="disguise-grid">
      {disguised.map((ex) => (
        <li class="card disguise-card">
          {ex.image
            ? <img src={ex.image} alt={ex.name} loading="lazy" />
            : <span class="disguise-emoji">{ex.emoji}</span>
          }
          <div class="disguise-body">
            <h2>{ex.name}</h2>
            <span class="verdict">🚨 Verdict: {ex.verdict}</span>
            <p>{ex.desc}</p>
          </div>
        </li>
      ))}
    </ul>

    <p class="outro dramatic">
      If someone suggests any of these, they are trying to make you lunge.
      Do not be deceived. Stay vigilant.
    </p>
  </section>
</BaseLayout>

<style>
  .disguise h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 38rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }

  .disguise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-md);
    list-style: none;
    padding: 0;
  }

  .disguise-card {
    text-align: center;
    padding: 0;
    overflow: hidden;
  }

  .disguise-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background-color: var(--color-bg-alt);
  }

  .disguise-emoji {
    font-size: 2.5rem;
    display: block;
    padding-top: var(--space-lg);
  }

  .disguise-body {
    padding: var(--space-sm) var(--space-md) var(--space-lg);
  }

  .disguise-card h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-xs);
  }

  .verdict {
    display: block;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .disguise-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .outro {
    text-align: center;
    margin-top: var(--space-xl);
  }
</style>
