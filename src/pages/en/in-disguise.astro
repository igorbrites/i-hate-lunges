---
import BaseLayout from "../../layouts/BaseLayout.astro";

const disguised = [
  { emoji: "🇧🇬", name: "Bulgarian Split Squat", verdict: "Split Squat", desc: "A lunge with your back foot on a bench. They added furniture to distract you. It's still a lunge." },
  { emoji: "🔀", name: "Split Squat", verdict: "Stationary Lunge", desc: "A lunge that doesn't move. They literally just renamed it. Zero effort to hide it." },
  { emoji: "🏃", name: "Step-Ups", verdict: "Vertical Lunge", desc: "A lunge aimed at the sky. You're still dropping into single-leg knee agony — just upward." },
  { emoji: "🔄", name: "Reverse Lunge", verdict: "Backwards Lunge", desc: "It's a lunge. But backwards. Revolutionary? No. Still a lunge? Absolutely." },
  { emoji: "🚶", name: "Walking Lunge", verdict: "Migratory Lunge", desc: "A lunge that travels. Now your suffering covers more ground. How delightful." },
  { emoji: "🤸", name: "Jump Lunge", verdict: "Airborne Lunge", desc: "A lunge with flight time. Because regular knee destruction wasn't extreme enough." },
  { emoji: "🎀", name: "Curtsy Lunge", verdict: "Fancy Lunge", desc: "A lunge dressed up for the ball. Crossing your leg behind you doesn't make it elegant. It makes it worse." },
  { emoji: "📐", name: "Lateral Lunge", verdict: "Sideways Lunge", desc: "A lunge that goes sideways. New direction, same betrayal." },
  { emoji: "⬇️", name: "Deficit Lunge", verdict: "Deeper Lunge", desc: "A lunge from a raised surface. More range of motion means more range of suffering." },
  { emoji: "🕐", name: "Clock Lunge", verdict: "Omnidirectional Lunge", desc: "Lunges in every direction. 360 degrees of regret." },
  { emoji: "🔫", name: "Pistol Squat", verdict: "Lunge's Cousin", desc: "Single-leg. Deep knee bend. Requires balance you don't have. If it walks like a lunge and hurts like a lunge…" },
  { emoji: "📦", name: "Box Step-Over", verdict: "Double Lunge", desc: "Step up, step down. That's two lunges. You've been double-charged." },
];
---

<BaseLayout title="Lunges in Disguise — I Hate Lunges">
  <section class="disguise animate-in">
    <h1>🕵️ Lunges in Disguise</h1>
    <p class="intro">
      The fitness industry thinks it can fool us by slapping a fancy name on a lunge.
      <strong>We see through the lies.</strong> Here is every exercise that is secretly
      just a lunge wearing a fake mustache.
    </p>

    <ul class="disguise-grid">
      {disguised.map((ex) => (
        <li class="card disguise-card">
          <span class="disguise-emoji">{ex.emoji}</span>
          <h2>{ex.name}</h2>
          <span class="verdict">🚨 Verdict: {ex.verdict}</span>
          <p>{ex.desc}</p>
        </li>
      ))}
    </ul>

    <p class="outro dramatic">
      If someone suggests any of these, they are trying to make you lunge.
      Do not be deceived. Stay vigilant.
    </p>
  </section>
</BaseLayout>

<style>
  .disguise h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 38rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }

  .disguise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-md);
    list-style: none;
    padding: 0;
  }

  .disguise-card {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
  }

  .disguise-emoji {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .disguise-card h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-xs);
  }

  .verdict {
    display: block;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .disguise-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .outro {
    text-align: center;
    margin-top: var(--space-xl);
  }
</style>
