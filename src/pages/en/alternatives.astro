---
import BaseLayout from "../../layouts/BaseLayout.astro";

const exercises = [
  { emoji: "🏋️", name: "Squats", desc: "All the quad burn, none of the existential crisis." },
  { emoji: "🦵", name: "Leg Press", desc: "Let the machine do the balancing. You focus on surviving." },
  { emoji: "🏃", name: "Step-Ups", desc: "Like a lunge, but you actually go somewhere. Progress." },
  { emoji: "🌉", name: "Glute Bridges", desc: "Work your glutes while lying down. Peak efficiency." },
  { emoji: "🚴", name: "Cycling", desc: "Seated. Moving. No wobbling. The holy trinity." },
  { emoji: "🧘", name: "Wall Sits", desc: "Just you, a wall, and the quiet dignity of not lunging." },
  { emoji: "🏊", name: "Swimming", desc: "Zero gravity, zero lunges. Aquatic paradise." },
  { emoji: "🚶", name: "Walking", desc: "Literally just walking. Still more dignified than a walking lunge." },
  { emoji: "🧗", name: "Stair Climbing", desc: "Functional? Yes. Humiliating? No. We approve." },
  { emoji: "💃", name: "Dancing", desc: "Express yourself through movement that doesn't require a spotter." },
];
---

<BaseLayout title="Lunge Alternatives — I Hate Lunges">
  <section class="alternatives animate-in">
    <h1>Exercises That Aren't Lunges</h1>
    <p class="intro">
      Behold: a curated list of <em>perfectly good exercises</em> that will work
      your legs without destroying your knees, your balance, or your dignity.
    </p>

    <ul class="exercise-grid">
      {exercises.map((ex) => (
        <li class="card exercise-card">
          <span class="exercise-emoji">{ex.emoji}</span>
          <h2>{ex.name}</h2>
          <p>{ex.desc}</p>
        </li>
      ))}
    </ul>

    <p class="outro dramatic">
      Notice how none of these involve plummeting toward the ground on a single
      trembling leg. You're welcome.
    </p>
  </section>
</BaseLayout>

<style>
  .alternatives h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 36rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }

  .exercise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--space-md);
    list-style: none;
    padding: 0;
  }

  .exercise-card {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
  }

  .exercise-emoji {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .exercise-card h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-xs);
  }

  .exercise-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .outro {
    text-align: center;
    margin-top: var(--space-xl);
  }
</style>
