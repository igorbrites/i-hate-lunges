---
import BaseLayout from "../../layouts/BaseLayout.astro";

const exercises = [
  { emoji: "🏋️", name: "Squats", desc: "All the quad burn, none of the existential crisis.", image: "/images/exercises/squats.jpeg" },
  { emoji: "🦵", name: "Leg Press", desc: "Let the machine do the balancing. You focus on surviving.", image: "/images/exercises/leg-press.jpeg" },
  { emoji: "", name: "Glute Bridges", desc: "Work your glutes while lying down. Peak efficiency.", image: "/images/exercises/glute-bridge.jpeg" },
  { emoji: "🚴", name: "Cycling", desc: "Seated. Moving. No wobbling. The holy trinity.", image: "/images/exercises/cycling.jpeg" },
  { emoji: "🧘", name: "Wall Sits", desc: "Just you, a wall, and the quiet dignity of not lunging.", image: "/images/exercises/wall-sit.jpg" },
  { emoji: "🏊", name: "Swimming", desc: "Zero gravity, zero lunges. Aquatic paradise.", image: "/images/exercises/swimming.jpeg" },
  { emoji: "🚶", name: "Walking", desc: "Literally just walking. Still more dignified than a walking lunge.", image: "/images/exercises/walking.jpg" },
  { emoji: "💃", name: "Dancing", desc: "Express yourself through movement that doesn't require a spotter.", image: "/images/exercises/dancing.jpeg" },
];
---

<BaseLayout title="Lunge Alternatives — I Hate Lunges">
  <section class="alternatives animate-in">
    <h1>Exercises That Aren't Lunges</h1>
    <p class="intro">
      Behold: a curated list of <em>perfectly good exercises</em> that will work
      your legs without destroying your knees, your balance, or your dignity.
    </p>

    <ul class="exercise-grid">
      {exercises.map((ex) => (
        <li class="card exercise-card">
          {ex.image
            ? <img src={ex.image} alt={ex.name} loading="lazy" />
            : <span class="exercise-emoji">{ex.emoji}</span>
          }
          <h2>{ex.name}</h2>
          <p>{ex.desc}</p>
        </li>
      ))}
    </ul>

    <p class="outro dramatic">
      Notice how none of these involve plummeting toward the ground on a single
      trembling leg. You're welcome.
    </p>
  </section>
</BaseLayout>

<style>
  .alternatives h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 36rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }

  .exercise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--space-md);
    list-style: none;
    padding: 0;
  }

  .exercise-card {
    text-align: center;
    padding: 0;
    overflow: hidden;
  }

  .exercise-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background-color: var(--color-bg-alt);
  }

  .exercise-emoji {
    font-size: 2.5rem;
    display: block;
    padding-top: var(--space-lg);
  }

  .exercise-card h2 {
    font-size: 1.2rem;
    margin: var(--space-sm) var(--space-md) var(--space-xs);
  }

  .exercise-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding: 0 var(--space-md) var(--space-lg);
  }

  .outro {
    text-align: center;
    margin-top: var(--space-xl);
  }
</style>
