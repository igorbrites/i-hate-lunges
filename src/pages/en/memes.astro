---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MemeGallery from "../../components/MemeGallery.astro";
---

<BaseLayout title="Meme Gallery — I Hate Lunges">
  <section class="memes-page animate-in">
    <h1>The Meme Gallery</h1>
    <p class="intro">
      A sacred archive of anti-lunge humor. Because laughter is the best
      medicine — especially for sore quads you got from lunges you shouldn't have
      done.
    </p>
    <MemeGallery lang="en" />
  </section>
</BaseLayout>

<style>
  .memes-page h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 36rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }
</style>
