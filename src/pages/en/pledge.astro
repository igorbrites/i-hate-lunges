---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PledgeForm from "../../components/PledgeForm.astro";
---

<BaseLayout title="The Anti-Lunge Pledge — I Hate Lunges">
  <section class="pledge-page animate-in">
    <h1>The Anti-Lunge Pledge</h1>
    <p class="intro">
      A solemn oath, binding in all gyms, parks, and living rooms across the
      known universe.
    </p>
    <PledgeForm lang="en" />
  </section>
</BaseLayout>

<style>
  .pledge-page h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 36rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }
</style>
