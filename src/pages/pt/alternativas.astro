---
import BaseLayout from "../../layouts/BaseLayout.astro";

const exercises = [
  { emoji: "🏋️", name: "Agachamento", desc: "Toda a queimação no quadríceps, nenhuma crise existencial.", image: "/images/exercises/squats.jpeg" },
  { emoji: "🦵", name: "Leg Press", desc: "Deixe a máquina cuidar do equilíbrio. Você foca em sobreviver.", image: "/images/exercises/leg-press.jpeg" },
  { emoji: "", name: "Elevação de Quadril", desc: "Trabalhe o glúteo deitado. Eficiência máxima.", image: "/images/exercises/glute-bridge.jpeg" },
  { emoji: "🚴", name: "Ciclismo", desc: "Sentado. Se movendo. Sem bambolear. A santíssima trindade.", image: "/images/exercises/cycling.jpeg" },
  { emoji: "🧘", name: "Cadeirinha na Parede", desc: "Só você, uma parede, e a dignidade silenciosa de não fazer afundo.", image: "/images/exercises/wall-sit.jpg" },
  { emoji: "🏊", name: "Natação", desc: "Gravidade zero, afundo zero. Paraíso aquático.", image: "/images/exercises/swimming.jpeg" },
  { emoji: "🚶", name: "Caminhar", desc: "Literalmente só caminhar. Ainda mais digno que um afundo caminhando.", image: "/images/exercises/walking.jpg" },
  { emoji: "💃", name: "Dançar", desc: "Expresse-se através de movimentos que não precisam de um observador.", image: "/images/exercises/dancing.jpeg" },
];
---

<BaseLayout title="Alternativas ao Afundo — Eu Odeio Afundo">
  <section class="alternatives animate-in">
    <h1>Exercícios Que Não São Afundos</h1>
    <p class="intro">
      Contemplem: uma lista curada de <em>exercícios perfeitamente bons</em> que
      vão trabalhar suas pernas sem destruir seus joelhos, seu equilíbrio ou sua
      dignidade.
    </p>

    <ul class="exercise-grid">
      {exercises.map((ex) => (
        <li class="card exercise-card">
          {ex.image
            ? <img src={ex.image} alt={ex.name} loading="lazy" />
            : <span class="exercise-emoji">{ex.emoji}</span>
          }
          <h2>{ex.name}</h2>
          <p>{ex.desc}</p>
        </li>
      ))}
    </ul>

    <p class="outro dramatic">
      Perceba como nenhum desses envolve despencar em direção ao chão em uma
      única perna trêmula. De nada.
    </p>
  </section>
</BaseLayout>

<style>
  .alternatives h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 36rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }

  .exercise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--space-md);
    list-style: none;
    padding: 0;
  }

  .exercise-card {
    text-align: center;
    padding: 0;
    overflow: hidden;
  }

  .exercise-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background-color: var(--color-bg-alt);
  }

  .exercise-emoji {
    font-size: 2.5rem;
    display: block;
    padding-top: var(--space-lg);
  }

  .exercise-card h2 {
    font-size: 1.2rem;
    margin: var(--space-sm) var(--space-md) var(--space-xs);
  }

  .exercise-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding: 0 var(--space-md) var(--space-lg);
  }

  .outro {
    text-align: center;
    margin-top: var(--space-xl);
  }
</style>
