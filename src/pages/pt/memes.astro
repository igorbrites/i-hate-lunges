---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MemeGallery from "../../components/MemeGallery.astro";
---

<BaseLayout title="Galeria de Memes — Eu Odeio Afundo">
  <section class="memes-page animate-in">
    <h1>A Galeria de Memes</h1>
    <p class="intro">
      Um arquivo sagrado de humor anti-afundo. Porque o riso é o melhor
      remédio — especialmente para os quadríceps doloridos que você ganhou de
      afundos que não deveria ter feito.
    </p>
    <MemeGallery lang="pt" />
  </section>
</BaseLayout>

<style>
  .memes-page h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 36rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }
</style>
