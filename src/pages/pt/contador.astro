---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LungeCounter from "../../components/LungeCounter.astro";
---

<BaseLayout title="Contador Livre de Afundos — Eu Odeio Afundo">
  <section class="counter-page animate-in">
    <h1>O Contador Livre de Afundos</h1>
    <p class="intro">
      Quantos dias você passou sem realizar um único afundo? Acompanhe sua
      sequência. Proteja sua dignidade. Nunca resete.
    </p>
    <LungeCounter lang="pt" />
  </section>
</BaseLayout>

<style>
  .counter-page h1 {
    text-align: center;
  }

  .intro {
    text-align: center;
    max-width: 36rem;
    margin: var(--space-md) auto var(--space-lg);
    font-size: 1.1rem;
  }
</style>
